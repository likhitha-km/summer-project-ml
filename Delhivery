1.3\n","\n","train_df['ftl_total_cost'] = train_df['ftl_cost'] + train_df['ftl_penalty']\n","train_df['carting_total_cost'] = train_df['carting_cost'] + train_df['carting_penalty']\n","\n","train_df['optimal_ftl'] = (train_df['ftl_total_cost'] < train_df['carting_total_cost']).astype(int)\n","\n","print(f'Optimal FTL rate: {train_df[\"optimal_ftl\"].mean()*100:.1f}%')\n","print(f'Actual FTL rate:  {train_df[\"route_type_bin\"].mean()*100:.1f}%')\n","\n","print('\\nAverage Economic Cost Comparison:')\n","print(f'FTL:     ₹{train_df[\"ftl_total_cost\"].mean():,.0f}')\n","print(f'Carting: ₹{train_df[\"carting_total_cost\"].mean():,.0f}')\n","\n","print('\\nOptimal Route Mix:')\n","print(train_df['optimal_ftl'].value_counts(normalize=True).rename({0:'Carting',1:'FTL'}) * 100)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SCpdxVk5WEvz","executionInfo":{"status":"ok","timestamp":1781505731992,"user_tz":-330,"elapsed":67,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"45464218-42b4-417c-b79a-95087b0bfe8f"},"execution_count":35,"outputs":[{"output_type":"stream","name":"stdout","text":["Optimal FTL rate: 79.5%\n","Actual FTL rate:  70.4%\n","\n","Average Economic Cost Comparison:\n","FTL:     ₹10,550\n","Carting: ₹15,253\n","\n","Optimal Route Mix:\n","optimal_ftl\n","FTL        79.510961\n","Carting    20.489039\n","Name: proportion, dtype: float64\n"]}]},{"cell_type":"code","source":["#Build route-type classifier with graph position features\n","def build_route_features(df_in, node_embeddings, hub_metrics_df):\n","    emb_dim = len(next(iter(node_embeddings.values())))\n","\n","    def get_emb(hub):\n","      return node_embeddings.get(hub, np.zeros(emb_dim))\n","\n","    src_emb = np.vstack([get_emb(h) for h in df_in['source_center']])\n","    dst_emb = np.vstack([get_emb(h) for h in df_in['destination_center']])\n","\n","    hm = hub_metrics_df.set_index('hub')\n","    graph_cols = ['betweenness','pagerank','in_degree','out_degree','bottleneck_score']\n","\n","    def get_hub_feat(hub):\n","        if hub in hm.index:\n","            return hm.loc[hub, graph_cols].values.astype(float)\n","        return np.zeros(len(graph_cols))\n","\n","    src_g = np.vstack([get_hub_feat(h) for h in df_in['source_center']])\n","    dst_g = np.vstack([get_hub_feat(h) for h in df_in['destination_center']])\n","\n","    trip_feat = df_in[['segment_osrm_distance','segment_osrm_time',\n","                        'hour_of_day','is_night','is_peak','corr_med_delay','corr_breach_rate']].values\n","\n","    return np.hstack([trip_feat, src_g, dst_g, src_emb, dst_emb])\n","\n","train_df2 = train_df.copy()\n","corr_agg = corridor_stats.groupby(['source_center','destination_center']).agg(\n","    corr_med_delay=('median_delay_ratio','median'),\n","    corr_breach_rate=('breach_rate','mean')\n",").reset_index()\n","train_df2 = train_df2.merge(corr_agg, on=['source_center','destination_center'], how='left')\n","train_df2['corr_med_delay'].fillna(train_df2['corr_med_delay'].median(), inplace=True)\n","train_df2['corr_breach_rate'].fillna(0.5, inplace=True)\n","\n","Xr = build_route_features(train_df2, node_embeddings, hub_metrics)\n","yr = train_df2['optimal_ftl'].values\n","\n","Xr_tr, Xr_te, yr_tr, yr_te = train_test_split(Xr, yr, test_size=0.2, random_state=SEED)\n","\n","route_clf = xgb.XGBClassifier(\n","    n_estimators=300, max_depth=6, learning_rate=0.05,\n","    subsample=0.8, colsample_bytree=0.8,\n","    use_label_encoder=False, eval_metric='logloss',\n","    random_state=SEED, verbosity=0\n",")\n","route_clf.fit(Xr_tr, yr_tr)\n","yr_pred = route_clf.predict(Xr_te)\n","print('Route Type Classifier:')\n","print(classification_report(yr_te, yr_pred, target_names=['Carting','FTL']))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XJPy_L2sW1QT","executionInfo":{"status":"ok","timestamp":1781506862517,"user_tz":-330,"elapsed":81510,"user":{"displayName":"Likhitha K M","userId":"12