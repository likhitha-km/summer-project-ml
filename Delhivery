   = 4\n","LR         = 0.025\n","\n","all_nodes  = list(G.nodes())\n","node2idx   = {n: i for i, n in enumerate(all_nodes)}\n","N          = len(all_nodes)\n","\n","def get_neighbors_weighted(G, node):\n","    nbrs = list(G.successors(node)) + list(G.predecessors(node))\n","    nbrs = list(set(nbrs))\n","    if not nbrs:\n","        return [], []\n","    weights = []\n","    for nb in nbrs:\n","        w = 0\n","        if G.has_edge(node, nb): w += G[node][nb].get('weight', 1.0)\n","        if G.has_edge(nb, node): w += G[nb][node].get('weight', 1.0)\n","        weights.append(max(w, 1e-6))\n","    total = sum(weights)\n","    return nbrs, [w/total for w in weights]\n","\n","def biased_walk(G, start, walk_len, p, q):\n","    walk = [start]\n","    prev = None\n","    for _ in range(walk_len - 1):\n","        cur  = walk[-1]\n","        nbrs, base_probs = get_neighbors_weighted(G, cur)\n","        if not nbrs:\n","            break\n","        if prev is None:\n","            probs = np.array(base_probs)\n","        else:\n","            probs = []\n","            for nb, bp in zip(nbrs, base_probs):\n","                if nb == prev:            probs.append(bp / p)\n","                elif G.has_edge(prev, nb) or G.has_edge(nb, prev): probs.append(bp)\n","                else:                     probs.append(bp / q)\n","            probs = np.array(probs)\n","        probs /= probs.sum()\n","        nxt = nbrs[np.random.choice(len(nbrs), p=probs)]\n","        walk.append(nxt)\n","        prev = cur\n","    return walk\n","\n","all_walks = []\n","nodes_arr = all_nodes.copy()\n","for _ in range(NUM_WALKS):\n","    random.shuffle(nodes_arr)\n","    for node in nodes_arr:\n","        all_walks.append(biased_walk(G, node, WALK_LEN, P, Q))\n","\n","print(f'Generated {len(all_walks)} walks. Training skipgram embeddings...')\n","\n","# Skipgram with negative sampling\n","rng  = np.random.default_rng(SEED)\n","W_in  = (rng.random((N, emb_dim)) - 0.5) / emb_dim   # target embeddings\n","W_out = np.zeros((N, emb_dim))                         # context embeddings\n","\n","def sigmoid(x):\n","    return 1.0 / (1.0 + np.exp(-np.clip(x, -10, 10)))\n","\n","NEG_SAMPLES = 3\n","node_freq   = np.ones(N)\n","for walk in all_walks:\n","    for n in walk:\n","        node_freq[node2idx[n]] += 1\n","neg_probs = node_freq ** 0.75\n","neg_probs /= neg_probs.sum()\n","\n","for epoch in range(N_EPOCHS):\n","    lr = LR * (1 - epoch / N_EPOCHS)\n","    total_loss = 0.0\n","    for walk in all_walks:\n","        idxs = [node2idx[n] for n in walk]\n","        for i, center in enumerate(idxs):\n","            ctx_range = idxs[max(0,i-WINDOW):i] + idxs[i+1:i+WINDOW+1]\n","            if not ctx_range: continue\n","            for ctx in ctx_range:\n","                # Positive sample\n","                score = sigmoid(W_in[center] @ W_out[ctx])\n","                grad  = lr * (1 - score)\n","                W_in[center]  += grad * W_out[ctx]\n","                W_out[ctx]    += grad * W_in[center]\n","                total_loss    -= np.log(score + 1e-9)\n","                # Negative samples\n","                negs = rng.choice(N, NEG_SAMPLES, p=neg_probs, replace=False)\n","                for neg in negs:\n","                    if neg == ctx: continue\n","                    score_n = sigmoid(W_in[center] @ W_out[neg])\n","                    grad_n  = lr * (0 - score_n)\n","                    W_in[center]  += grad_n * W_out[neg]\n","                    W_out[neg]    += grad_n * W_in[center]\n","                    total_loss    -= np.log(1 - score_n + 1e-9)\n","    print(f'  Epoch {epoch+1}/{N_EPOCHS}  loss={total_loss/len(all_walks):.2f}')\n","\n","# L2-normalise final embeddings\n","norms = np.linalg.norm(W_in, axis=1, keepdims=True) + 1e-9\n","W_in  = W_in / norms\n","\n","node_embeddings = {n: W_in[node2idx[n]] for n in all_nodes}\n","print(f'Embeddings ready for {len(node_embeddings)} hubs  (dim={emb_dim})')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LnSyDQkfozuy","executionInfo":{"status":"ok","timestamp":1781504740015,"user_tz":-330,"elapsed":674704,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"d416ae1e-6553-4894-b8c9-922e0b473c96"},"execution_count":24,"outputs":[{"output_type":"stream","name":"stdout","text":["Running Node2Vec random walks...\n","Generated 12720 walks. Training skipgram embeddings...\n","  Epoch 1/4  loss=106.34\n","  Epoch 2/4  loss=29.14\n","  Epoch 3/4  loss=26.01\n","  Epoch 4/4  loss=25.14\n","Embeddings ready for 1590 hubs  (dim=24)\n"]}]},{"cell_type":"code","source":["#PCA 2D visualization of Node2Vec embeddings\n","from sklearn.decomposition import PCA\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","emb_matrix = np.array([node_embeddings[n] for n in all_nodes])\n","\n","pca = PCA(n_components=2, random_state=SEED)\n","emb_2d = pca.fit_transform(emb_matrix)\n","\n","bs = hub_metrics.set_index('hub')['bottleneck_score']\n","scores_vis = [bs.get(n, 0) for n in all_nodes]\n","\n","fig, ax = plt.subplots(figsize=(14, 10))\n","\n","sc = ax.scatter(\n","    emb_2d[:, 0],\n","    emb_2d[:, 1],\n","    c=scores_vis,\n","    cmap='RdYlGn_r',\n","    alpha=0.75,\n","    s=28\n",")\n","\n","cbar = plt.colorbar(sc)\n","cbar.set_label('Bottleneck Score', fontsize=11)\n","\n","top5_hubs = top_hubs.head(5)['hub'].tolist()\n","\n","offsets = [\n","    (40, 30),\n","    (-50, 30),\n","    (40, -30),\n","    (-50, -30),\n","    (60, 0)\n","]\n","\n","for n, (dx, dy) in zip(top5_hubs, offsets):\n","\n","    if n not in all_nodes:\n","        continue\n","\n","    idx = all_nodes.index(n)\n","\n","    ax.scatter(\n","        emb_2d[idx, 0],\n","        emb_2d[idx, 1],\n","        s=160,\n","        color='red',\n","        edgecolor='black',\n","        linewidth=1.5,\n","        zorder=10\n","    )\n","\n","    ax.annotate(\n","        n[:15],\n","        xy=(emb_2d[idx, 0], emb_2d[idx, 1]),\n","        xytext=(dx, dy),\n","        textcoords='offset points',\n","        fontsize=9,\n","        fontweight='bold',\n","        color='darkred',\n","        bbox=dict(\n","            boxstyle='round,pad=0.25',\n","            fc='white',\n","            ec='red',\n","            alpha=0.95\n","        ),\n","        arrowprops=dict(\n","            arrowstyle='->',\n","            color='red',\n","            lw=1.8,\n","            shrinkA=5,\n","            shrinkB=5\n","        )\n","    )\n","\n","ax.set_title(\n","    'Node2Vec Embedding Space (PCA 2D)\\nColor = Bottleneck Score — Red hubs = highest structural risk (Top 5)',\n","    fontsize=15,\n","    fontweight='bold'\n",")\n","\n","ax.set_xlabel('Principal Component 1', fontsize=12)\n","ax.set_ylabel('Principal Component 2', fontsize=12)\n","\n","ax.grid(True, alpha=0.25)\n","\n","plt.tight_layout()\n","\n","\n","plt.savefig(\n","    f'{PATH}/embedding_space.png',\n","    dpi=300,\n","    bbox_inches='tight'\n",")\n","\n","plt.show()\n","\n","print('Saved: embedding_space.png')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":969},"id":"zjytsPDvyOo5","executionInfo":{"status":"ok","timestamp":1781504775510,"user_tz":-330,"elapsed":3018,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"28970ed5-d89b-4d6e-8306-5a2602c1b8aa"},"execution_count":25,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x1000 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saved: embedding_space.png\n"]}]},{"cell_type":"code","source":["#Feature builder\n","def build_features(df_in, node_embeddings, hub_metrics_df, corridor_stats_df, include_graph=True):\n","    df_in = df_in.copy()\n","    hm = hub_metrics_df.set_index('hub')\n","\n","    # Trip-level base features\n","    base_cols = ['segment_osrm_time','segment_osrm_distance','route_type_bin',\n","                 'hour_of_day','day_of_week','is_night','is_peak']\n","\n","    # Corridor-level aggregates joined from training stats\n","    corr_agg = corridor_stats_df.groupby(['source_center','destination_center']).agg(\n","        corr_med_delay=('median_delay_ratio','median'),\n","        corr_breach_rate=('breach_rate','mean')\n","    ).reset_index()\n","    df_in = df_in.merge(corr_agg, on=['source_center','destination_center'], how='left')\n","    df_in['corr_med_delay'].fillna(df_in['corr_med_delay'].median(), inplace=True)\n","    df_in['corr_breach_rate'].fillna(0.5, inplace=True)\n","\n","    trip_features = df_in[base_cols + ['corr_med_delay','corr_breach_rate']].values\n","\n","    if not include_graph:\n","        return trip_features, None\n","\n","    # Graph node features for source and destination\n","    graph_cols = ['betweenness','pagerank','in_degree','out_degree',\n","                  'in_strength','out_strength','clustering','bottleneck_score']\n","    def get_hub_feat(hub):\n","        if hub in hm.index:\n","            return hm.loc[hub, graph_cols].values.astype(float)\n","        return np.zeros(len(graph_cols))\n","\n","    src_graph = np.vstack([get_hub_feat(h) for h in df_in['source_center']])\n","    dst_graph = np.vstack([get_hub_feat(h) for h in df_in['destination_center']])\n","\n","    # Node2Vec embeddings for source and destination\n","    def get_emb(hub):\n","        return node_embeddings.get(hub, np.zeros(emb_dim))\n","\n","    src_emb = np.vstack([get_emb(h) for h in df_in['source_center']])\n","    dst_emb = np.vstack([get_emb(h) for h in df_in['destination_center']])\n","    # Difference embedding captures corridor asymmetry\n","    diff_emb = src_emb - dst_emb\n","\n","    graph_features = np.hstack([src_graph, dst_graph, src_emb, dst_emb, diff_emb])\n","    all_features = np.hstack([trip_features, graph_features])\n","    return trip_features, all_features\n","\n","y_train = train_df['segment_actual_time'].values\n","y_test  = test_df['segment_actual_time'].values\n","\n","X_train_base, X_train_graph = build_features(train_df, node_embeddings, hub_metrics, corridor_stats)\n","X_test_base,  X_test_graph  = build_features(test_df,  node_embeddings, hub_metrics, corridor_stats)\n","\n","print(f'Base features: {X_train_base.shape[1]}')\n","print(f'Graph-enhanced features: {X_train_graph.shape[1]}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ivWJvzKa6mxK","executionInfo":{"status":"ok","timestamp":1781504883655,"user_tz":-330,"elapsed":106517,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"611707e0-b6f8-4ad3-b27b-fc931dd13d30"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["Base features: 9\n","Graph-enhanced features: 97\n"]}]},{"cell_type":"code","source":["#Baseline: XGBoost on trip-level features only\n","base_model1 = xgb.XGBRegressor(\n","    n_estimators=700, max_depth=9, learning_rate=0.03,\n","    subsample=0.85, colsample_bytree=0.85, min_child_weight=3,\n","    objective='reg:squarederror', tree_method='hist',\n","    random_state=SEED, verbosity=0\n",")\n","\n","y_train_log = np.log1p(y_train)\n","y_test_log  = np.log1p(y_test)\n","\n","base_model1.fit(X_train_base, y_train_log,\n","               eval_set=[(X_test_base, y_test_log)],\n","               verbose=False)\n","\n","pred_base = np.expm1(base_model1.predict(X_test_base))\n","mae_base = mean_absolute_error(y_test, pred_base)\n","within15_base = np.mean(np.abs(pred_base - y_test) / (y_test + 1e-6) < 0.15)\n","print(f'Baseline XGBoost  → MAE: {mae_base:.3f} min | Within-15%: {within15_base*100:.1f}%')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lJso-V2U7nOO","executionInfo":{"status":"ok","timestamp":1781504898089,"user_tz":-330,"elapsed":11639,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"08b89661-116f-492f-c36a-6015b34e324a"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["Baseline XGBoost  → MAE: 10.344 min | Within-15%: 36.9%\n"]}]},{"cell_type":"code","source":["#Graph-Enhanced: XGBoost + Node2Vec + Graph Metrics\n","graph_xgb = xgb.XGBRegressor(\n","    n_estimators=800, max_depth=10, learning_rate=0.025,\n","    subsample=0.85, colsample_bytree=0.75, min_child_weight=3,\n","    reg_alpha=0.05, reg_lambda=0.8,\n","    objective='reg:squarederror', tree_method='hist',\n","    random_state=SEED, verbosity=0\n",")\n","graph_xgb.fit(X_train_graph, y_train_log,\n","              eval_set=[(X_test_graph, y_test_log)],\n","              verbose=False)\n","\n","pred_graph = np.expm1(graph_xgb.predict(X_test_graph))\n","mae_graph = mean_absolute_error(y_test, pred_graph)\n","within15_graph = np.mean(np.abs(pred_graph - y_test) / (y_test + 1e-6) < 0.15)\n","print(f'Graph-Enhanced XGBoost → MAE: {mae_graph:.3f} min | Within-15%: {within15_graph*100:.1f}%')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6jaJxfHc8NZq","executionInfo":{"status":"ok","timestamp":1781505036561,"user_tz":-330,"elapsed":121063,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"ec4a6a64-df30-4bb4-a786-440b52eb8bb8"},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["Graph-Enhanced XGBoost → MAE: 9.910 min | Within-15%: 39.0%\n"]}]},{"cell_type":"code","source":["# Deep Graph-Aware Neural Net (Keras) — stacked on Graph XGBoost predictions\n","\n","# Stack Graph XGBoost's own prediction in as an extra feature\n","xgb_pred_train_log = graph_xgb.predict(X_train_graph)\n","xgb_pred_test_log  = graph_xgb.predict(X_test_graph)\n","\n","X_train_graph = np.hstack([X_train_graph, xgb_pred_train_log.reshape(-1,1)])\n","X_test_graph  = np.hstack([X_test_graph,  xgb_pred_test_log.reshape(-1,1)])\n","\n","n_trip  = X_train_base.shape[1]\n","n_total = X_train_graph.shape[1]\n","n_graph = n_total - n_trip\n","\n","# Normalize\n","sc = StandardScaler()\n","Xg_train_sc = sc.fit_transform(X_train_graph)\n","Xg_test_sc  = sc.transform(X_test_graph)\n","\n","def build_dual_branch_model(n_trip, n_graph):\n","    inp_trip  = keras.Input(shape=(n_trip,),  name='trip_input')\n","    inp_graph = keras.Input(shape=(n_graph,), name='graph_input')\n","\n","    t = layers.Dense(32, activation='relu')(inp_trip)\n","    t = layers.BatchNormalization()(t)\n","    t = layers.Dense(16, activation='relu')(t)\n","\n","    g = layers.Dense(32, activation='relu', kernel_regularizer=keras.regularizers.l2(1e-3))(inp_graph)\n","    g = layers.BatchNormalization()(g)\n","    g = layers.Dropout(0.3)(g)\n","    g = layers.Dense(16, activation='relu')(g)\n","\n","    merged = layers.Concatenate()([inp_trip, inp_graph, t, g])\n","    x = layers.Dense(32, activation='relu')(merged)\n","    x = layers.Dropout(0.1)(x)\n","    out = layers.Dense(1, activation='linear', name='eta')(x)\n","\n","    model = keras.Model(inputs=[inp_trip, inp_graph], outputs=out)\n","    model.compile(optimizer=keras.optimizers.Adam(3e-4),\n","                  loss='mse',\n","                  metrics=['mae'])\n","    return model\n","\n","keras_model = build_dual_branch_model(n_trip, n_graph)\n","keras_model.summary()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":669},"id":"4W44T-Sn8WZY","executionInfo":{"status":"ok","timestamp":1781505126741,"user_tz":-330,"elapsed":15008,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"6f6df9ac-8579-4574-907e-998c5e206caf"},"execution_count":29,"outputs":[{"output_type":"display_data","data":{"text/plain":["\u001b[1mModel: \"functional\"\u001b[0m\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional\"</span>\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n","┃\u001b[1m \u001b[