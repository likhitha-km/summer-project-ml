estamp":1781510422036,"user_tz":-330,"elapsed":152,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"4a2b6ec1-c13b-4cd8-9eb3-201415baa17b"},"execution_count":90,"outputs":[{"output_type":"stream","name":"stdout","text":["Top 5 Hubs by Monthly Revenue Impact:\n","            hub  breach_trips  breach_rate  breach_cost_monthly  revenue_at_risk_monthly  total_impact_monthly  bottleneck_score\n","0  IND000000ACB         13338     0.820598            6669000.0                3001050.0             9670050.0          0.861984\n","1  IND562132AAA          5965     0.814334            2982500.0                1342125.0             4324625.0          0.658607\n","2  IND421302AAG          5771     0.911546            2885500.0                1298475.0             4183975.0          0.378583\n","3  IND411033AAA          2718     0.820652            1359000.0                 611550.0             1970550.0          0.352025\n","4  IND501359AAE          2268     0.894322            1134000.0                 510300.0             1644300.0          0.458035\n","\n","Total network monthly impact: ₹62,765,425\n","Top 3 hubs share: ₹18,178,650 (29.0%)\n"]}]},{"cell_type":"code","source":["#Hub upgrade ROI visualization\n","UPGRADE_CAPEX = 1_500_000\n","REDUCTION_RATES = [0.40, 0.50, 0.60]\n","\n","fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n","\n","top10_hubs = hub_breach.nlargest(10, 'total_impact_monthly')\n","x_pos = range(len(top10_hubs))\n","bars = axes[0].bar(x_pos, top10_hubs['total_impact_monthly']/1e5,\n","                   color=[plt.cm.RdYlGn_r(s) for s in top10_hubs['bottleneck_score']],\n","                   edgecolor='black', linewidth=0.5)\n","axes[0].set_xticks(x_pos)\n","axes[0].set_xticklabels([h[:15] for h in top10_hubs['hub']], rotation=45, ha='right', fontsize=8)\n","axes[0].set_ylabel('Monthly Impact (₹ Lakh)')\n","axes[0].set_title('Revenue-at-Risk by Hub (Monthly)\\nColor = Bottleneck Score', fontweight='bold')\n","for bar in bars[:3]:\n","    bar.set_edgecolor('darkred'); bar.set_linewidth(2)\n","axes[0].text(0.02, 0.98, 'Top 3 hubs outlined in red',\n","             transform=axes[0].transAxes, fontsize=9, va='top', color='darkred')\n","\n","top3 = hub_breach.nlargest(3, 'total_impact_monthly').reset_index(drop=True)\n","months = np.arange(1, 25)\n","for i, (_, row) in enumerate(top3.iterrows()):\n","    for j, rate in enumerate(REDUCTION_RATES):\n","        monthly_saving = row['total_impact_monthly'] * rate\n","        cumulative = months * monthly_saving - UPGRADE_CAPEX\n","        ls = ['-','--',':'][j]\n","        axes[1].plot(months, cumulative/1e5, linestyle=ls,\n","                     label=f'Hub {i+1} ({int(rate*100)}% reduction)',\n","                     color=['#e74c3c','#3498db','#2ecc71'][i])\n","axes[1].axhline(0, color='black', linewidth=1, linestyle='-')\n","axes[1].set_xlabel('Months Post-Upgrade')\n","axes[1].set_ylabel('Cumulative Net Benefit (₹ Lakh)')\n","axes[1].set_title('Upgrade ROI Payback — Top 3 Hubs\\n(Solid=40%, Dashed=50%, Dotted=60% breach reduction)', fontweight='bold')\n","axes[1].legend(fontsize=7, ncol=2)\n","axes[1].grid(True, alpha=0.3)\n","\n","plt.tight_layout()\n","plt.savefig(f'{PATH}/revenue_impact.png', dpi=150, bbox_inches='tight')\n","plt.show()"],"metadata":{"id":"r1tIJZYvqAY6","colab":{"base_uri":"https://localhost:8080/","height":469},"executionInfo":{"status":"ok","timestamp":1781510431235,"user_tz":-330,"elapsed":4560,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"3e71dc93-52c5-4765-c741-2eb15ddb8919"},"execution_count":91,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["#Generate Strategy Memo\n","best_graph_mae = min(mae_graph, mae_keras)\n","best_graph_w15 = max(within15_graph, within15_keras)\n","graph_advantage_mae = (mae_base - best_graph_mae) / mae_base * 100\n","graph_advantage_w15 = (best_graph_w15 - within15_base) * 100\n","\n","top5 = top5_bottlenecks.copy()\n","top3_hubs_list = top5.head(3)['hub'].tolist()\n","top3_impact_annual = top5.head(3)['total_impact_monthly'].sum() * 12\n","network_impact_annual = total_network_impact * 12\n","\n","def recommend_intervention(row):\n","    if row['betweenness'] > hub_metrics['betweenness'].quantile(0.9):\n","        return 'Parallel Route + Capacity Expansion'\n","    elif row['breach_rate'] > 0.35:\n","        return 'Facility Upgrade + Sort Technology'\n","    elif row['avg_delay_ratio'] > 2.0:\n","        return 'Route-Type Shift (Carting → FTL on peak hours)'\n","    else:\n","        return 'SLA Monitoring + Dynamic Rerouting'\n","\n","top5['intervention'] = top5.apply(recommend_intervention, axis=1)\n","\n","payback_months = UPGRADE_CAPEX / (top5.head(3)['total_impact_monthly'].mean() * 0.50)\n","sla_reduction_pct = top3_impact / total_network_impact * 100 * 0.5\n","\n","memo = f\"\"\"\n","═══════════════════════════════════════════════════════════════════════════════\n","              NETWORK OPERATIONS STRATEGY MEMO\n","              Delhivery — Graph Intelligence Initiative\n","              Prepared for: Head of Network Operations\n","═══════════════════════════════════════════════════════════════════════════════\n","\n","EXECUTIVE SUMMARY\n","─────────────────\n","We analyzed {len(df):,} trip segments across {G.number_of_nodes():,} facilities and\n","{G.number_of_edges():,} corridors that make up the network. On a majority of\n","shipments ({df['is_delayed'].mean()*100:.1f}%), actual transit time deviates from the\n","system's baseline routing estimate (OSRM) by more than 20%. This is not a\n","reflection of SLA performance today, but it does mean our routing engine\n","under-represents real network behavior — and that gap is precisely where a\n","graph-based view of the network creates value: by learning how delays\n","actually propagate through hubs and corridors, we can produce ETAs that hold\n","up under real operating conditions.\n","\n","MODEL IMPACT — FROM ROUTING ESTIMATE TO RELIABLE ETA\n","──────────────────────────────────────────────────────\n","Augmenting our ETA model with network structure (hub centrality, corridor\n","congestion patterns, and facility connectivity) improves prediction error\n","from {mae_base:.2f} to {best_graph_mae:.2f} minutes ({graph_advantage_mae:.1f}% reduction) and lifts the\n","share of shipments with an ETA within 15% of actual delivery time from\n","{within15_base*100:.1f}% to {best_graph_w15*100:.1f}% (+{graph_advantage_w15:.1f} points). In practical terms: more\n","shipments arrive within the window we promise customers, fewer last-minute\n","escalations, and capacity planning that reflects how the network truly\n","behaves — not just how it would behave on an empty road.\n","\n","TOP 5 BOTTLENECK HUBS — SLA BREACH CONTRIBUTION\n","────────────────────────────────────────────────\n","\"\"\"\n","for i, row in top5.iterrows():\n","    memo += f\"\"\"\n","#{i+1}. Hub: {row['hub']}\n","   Monthly Breach Trips : {int(row['breach_trips']):,} ({row['breach_rate']*100:.1f}% of outgoing)\n","   Monthly Revenue Impact: ₹{row['total_impact_monthly']/1e5:.1f}L (SLA penalties + churn risk)\n","   Bottleneck Score      : {row['bottleneck_score']:.3f} (graph centrality + volume + delay)\n","   Recommended Action    : {row['intervention']}\n","\"\"\"\n","\n","memo += f\"\"\"\n","CORRIDOR-SPECIFIC INTERVENTIONS\n","────────────────────────────────\n","- Chronic corridors (transit time consistently >20% over OSRM): {len(chronic_corridors):,} corridors\n","  identified, accounting for {chronic_corridors['sla_breach_volume'].sum():,.0f} breach-trips in the\n","  training window.\n","\n","- Recommended intervention by corridor profile:\n","  – Long haul (>300km) with high breach rates → shift to FTL (cost-neutral above 350km)\n","  – Urban last-mile, night operations → add a dedicated night shift at the source hub\n","  – Medium-distance corridors with seasonal spikes → pre-position surge capacity at top 3 hubs\n","\n","QUANTIFIED IMPACT OF UPGRADING TOP 3 HUBS\n","──────────────────────────────────────────\n","- Current annual revenue at risk (full network): ₹{network_impact_annual/1e7:.1f} Cr\n","- Annual impact from top 3 hubs alone          : ₹{top3_impact_annual/1e7:.1f} Cr\n","- Expected SLA breach reduction (50% target)   : ~{sla_reduction_pct:.1f}% of total network breaches\n","- Upgrade capex per hub                        : ₹{UPGRADE_CAPEX/1e5:.0f}L (est.)\n","- Estimated payback period (moderate scenario) : under 1 month (~{payback_months:.1f} months) —\n","  upgrade cost is recovered almost immediately through reduced SLA penalties\n","  and retained revenue, making this one of the highest-return interventions\n","  available to the network today\n","- 12-month net recovery (3 hubs, 50% reduction): ₹{(top3_impact_annual*0.5 - 3*UPGRADE_CAPEX)/1e5:.0f}L\n","\n","FTL vs CARTING OPTIMIZATION\n","────────────────────────────\n","- {actual_vs_optimal_mismatch*100:.1f}% of current route assignments are sub-optimal based on\n","  distance, breach rate, and graph position.\n","- Aligning route-type decisions to this framework saves an estimated\n","  ₹{suboptimal_trips * avg_cost_diff / 1e5:.0f}L/month in operating cost.\n","- Guiding principle: favor FTL when distance exceeds 350km, or when the\n","  corridor's breach rate exceeds 35%.\n","\n","RECOMMENDED NEXT STEPS (0–30 DAYS)\n","─────────────────────────────────────\n","1. Run the graph-enhanced ETA model in shadow mode alongside OSRM to validate\n","   accuracy gains on live shipments before any customer-facing change\n","2. Instrument the top 3 bottleneck hubs with real-time dwell-time tracking\n","3. Pilot FTL conversion on the top 5 sub-optimal Carting corridors (>400km, breach >30%)\n","4. Stand up automated alerting for any corridor exceeding a 40% breach rate\n","\n","MEDIUM-TERM ROADMAP (30–90 DAYS)\n","─────────────────────────────────\n","1. Begin facility upgrade planning for the top 2 hubs, prioritized by payback\n","2. Move the graph-enhanced ETA model from shadow mode into a controlled pilot\n","   on a subset of corridors; validate against OSRM before expanding coverage,\n","   and only proceed to a phased production rollout once performance holds\n","   up consistently across pilot routes\n","3. Integrate the route-type classifier into the dispatch system — an estimated\n","   ₹{suboptimal_trips * avg_cost_diff / 1e5 * 3:.0f}L in quarterly savings\n","4. Assess parallel-route feasibility for the highest-betweenness hub in the network\n","\n","═══════════════════════════════════════════════════════════════════════════════\n","\"\"\"\n","\n","print(memo)\n","\n","with open(f'{PATH}/strategy_memo.txt', 'w') as f:\n","    f.write(memo)\n","print('Saved: strategy_memo.txt')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LWfePFJzImwt","executionInfo":{"status":"ok","timestamp":1781511256290,"user_tz":-330,"elapsed":55,"user":{"displayName":"Likhitha K M","userId":"12382500246314620021"}},"outputId":"27c4d39e-8a1d-4854-d1fc-95ce9e84be23"},"execution_count":100,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","═══════════════════════════════════════════════════════════════════════════════\n","              NETWORK OPERATIONS STRATEGY MEMO\n","              Delhivery — Graph Intelligence Initiative\n","              Prepared for: Head of Network Operations\n","═══════════════════════════════════════════════════════════════════════════════\n","\n","EXECUTIVE SUMMARY\n","─────────────────\n","We analyzed 140,859 trip segments across 1,590 facilities and\n","2,506 corridors that make up the network. On a majority of\n","shipments (84.8%), actual transit time deviates from the\n","system's baseline routing estimate (OSRM) by more than 20%. This is not a\n","reflection of SLA performance today, but it does mean our routing engine\n","under-represents real network behavior — and that gap is precisely where a\n","graph-based view of the network creates value: by learning how delays\n","actually propagate through hubs and corridors, we can produce ETAs that hold\n","up under real operating conditions.\n","\n","MODEL IMPACT — FROM ROUTING ESTIMATE TO RELIABLE ETA\n","──────────────────────────────────────────────────────\n","Augmenting our ETA model with network structure (hub centrality, corridor\n","congestion patterns, and facility connectivity) improves prediction error\n","from 10.34 to 9.91 minutes (4.2% reduction) and lifts the\n","share of shipments with an ETA within 15% of actual delivery time from\n","36.9% to 41.1% (+4.2 points). In practical terms: more\n","shipments arrive within the window we promise customers, fewer last-minute\n","escalations, and capacity planning that reflects how the network truly\n","behaves — not just how it would behave on an empty road.\n","\n","TOP 5 BOTTLENECK HUBS — SLA BREACH CONTRIBUTION\n","────────────────────────────────────────────────\n","\n","#1. Hub: IND000000ACB\n","   Monthly Breach Trips : 13,338 (82.1% of outgoing)\n","   Monthly Revenue Impact: ₹96.7L (SLA penalties + churn risk)\n","   Bottleneck Score      : 0.862 (graph centrality + volume + delay)\n","   Recommended Action    : Parallel Route + Capacity Expansion\n","\n","#2. Hub: IND562132AAA\n","   Monthly Breach Trips : 5,965 (81.4% of outgoing)\n","   Monthly Revenue Impact: ₹43.2L (SLA penalties + churn risk)\n","   Bottleneck Score      : 0.659 (graph centrality + volume + delay)\n","   Recommended Action    : Parallel Route + Capacity Expansion\n","\n","#3. Hub: IND421302AAG\n","   Monthly Breach Trips : 5,771 (91.2% of outgoing)\n","   Monthly Revenue Impact: ₹41.8L (SLA penalties + churn risk)\n","   Bottleneck Score      : 0.379 (graph centrality + volume + delay)\n","   Recommended Action    : Parallel Route + Capacity Expansion\n","\n","#4. Hub: IND411033AAA\n","   Monthly Breach Trips : 2,718 (82.1% of outgoing)\n","   Monthly Revenue Impact: ₹19.7L (SLA penalties + churn risk)\n","   Bottleneck Score      : 0.352 (graph centrality + volume + delay)\n","   Recommended Action    : Parallel Route + Capacity Expansion\n","\n","#5. Hub: IND501359AAE\n","   Monthly Breach Trips : 2,268 (89.4% of outgoing)\n","   Monthly Revenue Impact: ₹16.4L (SLA penalties + churn risk)\n","   Bottleneck Score      : 0.458 (graph centrality + volume + delay)\n","   Recommended Action    : Parallel Route + Capacity Expansion\n","\n","CORRIDOR-SPECIFIC INTERVENTIONS\n","────────────────────────────────\n","- Chronic corridors (transit time consistently >20% over OSRM): 1,853 corridors\n","  identified, accounting for 83,915 breach-trips in the\n","  training window.\n","\n","- Recommended intervention by corridor profile:\n","  – Long haul (>300km) with high breach rates → shift to FTL (cost-neutral above 350km)\n","  – Urban last-mile, night operations → add a dedicated night shift at the source hub\n","  – Medium-distance corridors with seasonal spikes → pre-position surge capacity at top 3 hubs\n","\n","QUANTIFIED IMPACT OF UPGRADING TOP 3 HUBS\n","──────────────────────────────────────────\n","- Current annual revenue at risk (full network): ₹75.3 Cr\n","- Annual impact from top 3 hubs alone          : ₹21.8 Cr\n","- Expected SLA breach reduction (50% target)   : ~14.5% of total network breaches\n","- Upgrade capex per hub                        : ₹15L (est.)\n","- Estimated payback period (moderate scenario) : under 1 month (~0.5 months) —\n","  upgrade cost is recovered almost immediately through reduced SLA penalties\n","  and retained revenue, making this one of the highest-return interventions\n","  available to the network today\n","- 12-month net recovery (3 hubs, 50% reduction): ₹1046L\n","\n","FTL vs CARTING OPTIMIZATION\n","────────────────────────────\n","- 37.1% of current route assignments are sub-optimal based on\n","  distance, breach rate, and graph position.\n","- Aligning route-type decisions to this framework saves an estimated\n","  ₹1966L/month in operating cost.\n","- Guiding principle: favor FTL when distance exceeds 350km, or when the\n","  corridor's breach rate exceeds 35%.\n","\n","RECOMMENDED NEXT STEPS (0–30 DAYS)\n","─────────────────────────────────────\n","1. Run the graph-enhanced ETA model in shadow mode alongside OSRM to validate\n","   accuracy gains on live shipments before any customer-facing change\n","2. Instrument the top 3 bottleneck hubs with real-time dwell-time tracking\n","3. Pilot FTL conversion on the top 5 sub-optimal Carting corridors (>400km, breach >30%)\n","4. Stand up automated alerting for any corridor exceeding a 40% breach rate\n","\n","MEDIUM-TERM ROADMAP (30–90 DAYS)\n","─────────────────────────────────\n","1. Begin facility upgrade planning for the top 2 hubs, prioritized by payback\n","2. Move the graph-enhanced ETA model from shadow mode into a controlled pilot\n","   on a subset of corridors; validate against OSRM before expanding coverage,\n","   and only proceed to a phased production rollout once performance holds\n","   up consistently across pilot routes\n","3. Integrate the route-type classifier into the dispatch system — an estimated\n","   ₹5897L in quarterly savings\n","4. Assess parallel-route feasibility for the highest-betweenness hub in the network\n","\n","═══════════════════════════════════════════════════════════════════════════════\n","\n","Saved: strategy_memo.txt\n"]}]},{"cell_type":"code","source":["#Save all the artifacts needed for dashboard\n","hub_metrics.to_csv(f'{PATH}/hub_metrics.csv', index=False)\n","edge_df.to_csv(f'{PATH}/edge_metrics.csv', index=False)\n","top5_bottlenecks.to_csv(f'{PATH}/top5_bottlenecks.csv', index=False)\n","\n","graph_xgb.save_model(f'{PATH}/graph_xgb_model.json')\n","route_clf.save_model(f'{PATH}/route_clf_model.json')\n","keras_model.save(f'{PATH}/keras_eta_model.keras')\n","\n","print('All artifacts saved'